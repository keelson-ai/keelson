{
  "name": "keelson",
  "version": "1.0.0",
  "type": "module",
  "description": "AI agent security scanner",
  "license": "Apache-2.0",
  "bin": {
    "keelson": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "clean": "rm -rf dist",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "axios": "1.16.0",
    "better-sqlite3": "12.9.0",
    "chalk": "5.6.2",
    "cheerio": "1.2.0",
    "commander": "14.0.3",
    "execa": "9.6.1",
    "fastest-levenshtein": "1.0.16",
    "ink": "6.8.0",
    "js-rouge": "3.2.0",
    "lru-cache": "11.3.5",
    "nunjucks": "3.2.4",
    "p-queue": "9.2.0",
    "p-retry": "7.1.1",
    "pino": "10.3.1",
    "playwright-extra": "4.3.6",
    "proxy-agent": "7.0.0",
    "react": "19.2.5",
    "yaml": "2.8.4",
    "zod": "4.4.3"
  },
  "optionalDependencies": {
    "playwright": "1.59.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.5.0",
    "@types/nunjucks": "3.2.6",
    "@types/react": "19.2.14",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "husky": "9.1.7",
    "ink-testing-library": "4.0.0",
    "lint-staged": "16.4.0",
    "nock": "14.0.11",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,yaml,yml,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
