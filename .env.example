# ─── Pentis Service — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Target LLM API ────────────────────────────────────────────────────────────
# API key sent as Bearer token to the target endpoint
PENTIS_API_KEY=your-api-key-here

# Base URL of the OpenAI-compatible chat completions endpoint to scan
PENTIS_TARGET_URL=http://host.docker.internal:8080/v1/chat/completions

# Model name passed in the request body
PENTIS_MODEL=gpt-4o

# ── Service Settings ───────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
PENTIS_LOG_LEVEL=INFO

# Port the uvicorn server listens on (also update ports: in docker-compose.yml)
PENTIS_PORT=8000

# ── Attack Engine ─────────────────────────────────────────────────────────────
# Seconds to sleep between individual attack requests (rate limiting)
PENTIS_REQUEST_DELAY=1

# Maximum number of concurrent scan workers
PENTIS_CONCURRENCY=4

# Attack categories to run (comma-separated; leave empty for all)
# Possible values: goal-adherence, tool-safety, memory-integrity
PENTIS_CATEGORIES=

# ── Always-Live Red Team ──────────────────────────────────────────────────────
# Default scan interval for scheduled red team cycles (seconds; default: 6 hours)
PENTIS_SCAN_INTERVAL=21600

# Health check interval for monitored targets (seconds; default: 5 minutes)
PENTIS_HEALTH_CHECK_INTERVAL=300

# Maximum number of concurrent scans running simultaneously
PENTIS_MAX_CONCURRENT_SCANS=3

# Webhook URL for event delivery (Slack, PagerDuty, etc.)
PENTIS_WEBHOOK_URL=

# ── Attacker LLM (for attack generation & mutations) ──────────────────────────
# API key for the attacker LLM used to generate novel attacks
PENTIS_ATTACKER_API_KEY=

# Model to use for attack generation
PENTIS_ATTACKER_MODEL=gpt-4o
