# Development image — includes dev dependencies and hot-reload
FROM python:3.11-slim

WORKDIR /app

# Install uv
RUN pip install --no-cache-dir uv

# Copy dependency manifests for layer caching
COPY pyproject.toml uv.lock ./

# Install all dependencies including dev extras (pytest, ruff, pyright)
RUN uv sync --extra dev

# Create non-root user
RUN useradd -m -u 1000 keelson && \
    chown -R keelson:keelson /app

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app/src"
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Drop to non-root
USER keelson

EXPOSE 8000

# Source is mounted at runtime via docker-compose volume for hot-reload
CMD ["uvicorn", "keelson_service.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
